/**
 * ============================================================
 * ESP32-S3 DHT11 温湿度传感器示例
 * ============================================================
 * 
 * 学习目标：读取环境温度和湿度
 * 
 * DHT11 参数：
 * - 温度范围：0-50°C (±2°C精度)
 * - 湿度范围：20-90%RH (±5%精度)
 * - 数据引脚只需1根（单总线通信）
 * 
 * 接线：
 *   DHT11模块  →  ESP32-S3
 *   VCC (电源+) →  3.3V
 *   GND (电源-) →  GND
 *   DATA (数据) →  GPIO 4
 */

// ============================================================
// 第1步：加载库
// ============================================================

#include <Arduino.h>      // Arduino 基础库
#include <DHT.h>          // DHT传感器专用库

// ============================================================
// 第2步：定义引脚
// ============================================================

#define DHT_PIN  4   // DATA引脚连接到GPIO4

// ============================================================
// 第3步：创建DHT对象
// ============================================================

// DHT dht(引脚, 传感器型号);
// 型号可选：DHT11 / DHT22 / DHT21
DHT dht(DHT_PIN, DHT11);

// ============================================================
// 第4步：初始化（程序启动时执行一次）
// ============================================================

void setup() {
    // 启动串口通信
    Serial.begin(115200);
    
    // 初始化DHT传感器
    dht.begin();
    
    Serial.println("DHT11 Ready");
    Serial.println("Reading sensor data...");
}

// ============================================================
// 第5步：主循环（反复执行）
// ============================================================

void loop() {
    // 读取湿度（返回值是浮点数，如 65.5）
    float humidity = dht.readHumidity();
    
    // 读取温度（返回值是浮点数，如 25.3）
    float temperature = dht.readTemperature();
    
    // ==========================================
    // isnan()：检查是否是"非数字"
    // 如果读取失败，返回NaN（not a number）
    // || 或运算，两个有一个为真就进入if
    // ==========================================
    if (isnan(humidity) || isnan(temperature)) {
        // 读取失败，打印错误信息
        Serial.println("DHT11 Read Error!");
        
        // 延时2秒后重试
        // 不用delay太久，传感器需要时间稳定
        delay(2000);
        
        // return：提前结束本次loop，等待下次
        return;
    }
    
    // 打印湿度
    Serial.print("Humidity: ");
    // Serial.print()：打印不换行
    Serial.print(humidity);
    Serial.print("%  ");    // %是百分号
    
    // 打印温度
    Serial.print("Temperature: ");
    Serial.print(temperature);
    Serial.println(" C");  // println：打印并换行
    
    // 每2秒读取一次
    // DHT11最快每秒读取1次，太快读取会失败
    delay(2000);
}

/**
 * ============================================================
 * DHT11 数据手册
 * ============================================================
 * 
 * 【单总线通信】
 * - 只需要1根数据线
 * - 数据格式：温度(16bit) + 湿度(16bit) + 校验(8bit)
 * - 通信时序：主机发送开始信号 → DHT响应 → 发送40bit数据
 * 
 * 【引脚说明】
 * VCC  - 电源正极 (3.3V-5V)
 * GND  - 电源负极
 * DATA - 数据引脚（需要接4.7K-10K上拉电阻）
 * 
 * 【常用函数】
 * dht.readHumidity()     - 读取湿度（百分比）
 * dht.readTemperature()  - 读取温度（摄氏度）
 * dht.readTemperatureF() - 读取温度（华氏度）
 * dht.computeHeatIndex() - 计算体感温度
 */